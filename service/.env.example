# Print Genie glue service — STANDALONE env (running `uvicorn app.main:app` directly, not via Docker).
# Copy to service/.env (gitignored) and fill in. For the Docker path use docker/.env.example instead.
# Note the localhost URLs below differ from the Docker service-name URLs.

# --- Phase 1: alerts ---
DISCORD_WEBHOOK_URL=

# --- Phase 2: Supabase job log (httpx/PostgREST — no supabase SDK needed) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Phase 2: Meshy STL preflight (free tier) ---
MESHY_API_KEY=
MESHY_BASE_URL=https://api.meshy.ai

# --- Phase 3: BROski economy ---
HYPERCODE_CORE_URL=http://localhost:8000
ECONOMY_AWARD_PATH=/economy/award-dev-xp
OWNER_DISCORD_ID=418075243404591106
XP_PER_SUCCESS=50

# --- Service ---
PRINTGENIE_WEBHOOK_SECRET=change-me
PRINTGUARD_BASE_URL=http://localhost:8000

# --- Phase 4 (spike, off by default): Anycubic cloud pause — token-based auth ---
ANYCUBIC_CLOUD_API_PATH=
ANYCUBIC_ACCESS_TOKEN=
ANYCUBIC_PRINTER_ID=
PAUSE_COOLDOWN_S=120
AUTO_PAUSE_ENABLED=false
