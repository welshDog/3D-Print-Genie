# Print Genie — glue service environment (standalone, not via Docker)
# Copy to service/.env and fill in. NEVER commit .env — it's gitignored.
#
# When running via docker/docker-compose.yml, use docker/.env.example instead.

# --- Phase 1: alerts ---
# Discord channel webhook URL
# Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=

# --- Phase 2: Supabase job log ---
# Use the service-role key (bypasses RLS). Never expose this client-side.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Phase 2: Meshy STL preflight (free, no credits) ---
# Get your key at https://www.meshy.ai/api
MESHY_API_KEY=
MESHY_BASE_URL=https://api.meshy.ai

# --- Phase 3: BROski economy ---
# HyperCode core URL (local or remote)
HYPERCODE_CORE_URL=http://localhost:8000
ECONOMY_AWARD_PATH=/economy/award-dev-xp
OWNER_DISCORD_ID=418075243404591106
XP_PER_SUCCESS=50

# --- Glue service security ---
# Shared secret — PrintGuard must send this as X-Printgenie-Secret header.
# Generate a strong random value: python -c "import secrets; print(secrets.token_hex(32))"
PRINTGENIE_WEBHOOK_SECRET=change-me

# PrintGuard base URL (same machine = localhost:8000, Docker = http://printguard:8000)
PRINTGUARD_BASE_URL=http://localhost:8000

# --- Phase 4 (opt-in, off by default): Anycubic cloud pause ---
# Only enable once spike in spikes/anycubic_cloud_pause.md is proven on your Kobra X.
# Auth is ACCESS-TOKEN based — see spike doc for how to capture the token.
ANYCUBIC_CLOUD_API_PATH=
ANYCUBIC_ACCESS_TOKEN=
ANYCUBIC_PRINTER_ID=
PAUSE_COOLDOWN_S=120
AUTO_PAUSE_ENABLED=false
