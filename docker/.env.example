# Print Genie environment — copy to .env (gitignored) and fill in.

# --- Phase 1: alerts ---
# Discord channel webhook (Server Settings → Integrations → Webhooks → New Webhook → Copy URL)
# Live deployment uses the dedicated #print-genie channel on the BROski guild.
DISCORD_WEBHOOK_URL=

# --- Phase 2: Supabase job log ---
# Use a dedicated project/schema. Service-role key stays server-side only (never ship to a client).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Phase 2: Meshy STL preflight (free tier) ---
# https://www.meshy.ai/api  →  the printability endpoint consumes no credits.
MESHY_API_KEY=

# --- Phase 3: BROski economy ---
# Existing HyperCode core endpoint that banks durable dev XP.
HYPERCODE_CORE_URL=http://host.docker.internal:8000
ECONOMY_AWARD_PATH=/api/v1/economy/award-dev-xp
# Core master API_KEY — the dev-xp sink is X-API-Key gated (same key the economy consumer uses)
HYPERCODE_API_KEY=
OWNER_DISCORD_ID=418075243404591106
XP_PER_SUCCESS=50

# --- Glue service ---
# Shared secret PrintGuard signs its webhook with (set the same value in PrintGuard's webhook config).
PRINTGENIE_WEBHOOK_SECRET=change-me
PRINTGUARD_BASE_URL=http://printguard:8000

# --- Phase 4 (spike, optional/off by default): Anycubic cloud pause ---
# Auth is ACCESS-TOKEN based (NOT email/password). See spikes/anycubic_cloud_pause.md.
# Reuses the maintained anycubic_cloud_api client — clone hass-anycubic_cloud and point at its
# .../custom_components/anycubic_cloud dir.
ANYCUBIC_CLOUD_API_PATH=
ANYCUBIC_ACCESS_TOKEN=
ANYCUBIC_PRINTER_ID=
PAUSE_COOLDOWN_S=120
AUTO_PAUSE_ENABLED=false
